# =====================
# MEDIMAP GEO · 환경변수
# =====================

# Public site URL (sitemap / llms.txt / canonical에 사용)
NEXT_PUBLIC_SITE_URL=https://medimap-geo.vercel.app

# Supabase (없으면 mock-data로 작동)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM provider 선택: chatgpt | claude | gemini | perplexity | stub
LLM_PROVIDER=stub

# LLM API keys (선택한 provider에 맞게 입력)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# Cron 보호용 시크릿 — /api/publish/auto, /api/monitor/tick에서 사용
CRON_SECRET=

# IndexNow (Bing/Yandex 즉시 인덱싱)
INDEXNOW_KEY=
INDEXNOW_HOST=medimap-geo.vercel.app
